# macOS
.DS_Store

# Editor / tooling cruft
*.swp
.vscode/
.idea/

# Node (none committed yet, but keep it out if it ever appears)
node_modules/

# Raw GTFS feed. We parse it once into data/*.geojson and commit that, not the
# source. Regenerate with: node scripts/build-routes.mjs (see CLAUDE.md).
gtfs-src/

# Netlify local CLI state
.netlify/

# Debug-only disambiguation output. Large and fully regenerable, so we keep it
# out of git. Build before opening the matching debug page (see CLAUDE.md):
#   node scripts/detect-corridors.mjs  -> debug-corridors.html
#   node scripts/spread-routes.mjs     -> spread-preview.html
data/corridors-debug.geojson
data/routes-spread-debug.geojson
data/spike-division-debug.geojson

# Raw OSM road network pulled from Overpass for road-normalization. Regenerable
# (see the Overpass fetch), so kept out of git like the GTFS source.
osm-src/
data/routes-matched-debug.geojson
data/routes-matched-spread-debug.geojson
data/routes-merged-debug.geojson
data/routes-merged-spread-debug.geojson

# Note: data/routes-final.geojson (the polish-pass output) is COMMITTED on purpose:
# it is the static geometry the deployed index.html draws (no build step on Netlify).

# Accumulated live-vehicle GPS log from scripts/collect-vehicles.mjs. Large and
# always growing; we commit only the DERIVED route geometry, not the raw log
# (same "parse once, commit static" rule as the GTFS source).
data/vehicle-log.ndjson
